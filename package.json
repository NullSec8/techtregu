{
  "name": "techtregu",
  "version": "1.0.0",
  "description": "Tech marketplace for computers and devices",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "start": "npm run start --prefix server",
    "build": "npm run build --prefix client",
    "make-admin": "npm run make-admin --prefix server --",
    "install-client": "npm install --prefix client",
    "install-server": "npm install --prefix server",
    "install-all": "npm run install-client && npm run install-server",
    "prepare": "husky",
    "lint:server": "eslint server/ --config server/eslint.config.js",
    "lint:client": "npm run lint --prefix client",
    "lint": "npm run lint:server && npm run lint:client",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "marketplace",
    "tech",
    "react",
    "nodejs",
    "mysql"
  ],
  "author": "",
  "license": "ISC"
}
