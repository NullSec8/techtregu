# =============================================================================
# TechTregu - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# MySQL / Database
# ---------------------------------------------------------------------------
# The server creates the database automatically if it does not exist.
# Required for: all features
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=techtregu

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development      # "development" | "production" | "test"
PORT=5000                 # HTTP server port

# ---------------------------------------------------------------------------
# JWT & Session
# ---------------------------------------------------------------------------
# Required for: authentication, socket auth, CSRF protection
# Use a long random string (32+ characters). The server REFUSES to start in
# production if this is missing or shorter than 32 characters.
JWT_SECRET=replace_with_a_long_random_string

# Required for: Google OAuth in production only (falls back to JWT_SECRET in dev)
# Used by express-session. Set a unique value if Google OAuth is enabled in
# production; the server exits with a FATAL error if missing.
# SESSION_SECRET=

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
# Required for: all API requests from the browser
# CLIENT_URL is the primary browser origin for CORS + Socket.IO.
# CORS_ORIGINS overrides CLIENT_URL when set (comma-separated for multiple
# origins, e.g. production + preview/staging).
CLIENT_URL=http://localhost:5173
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# ---------------------------------------------------------------------------
# Google OAuth (optional)
# ---------------------------------------------------------------------------
# Uncomment to enable "Sign in with Google".
# Required for: Google OAuth login feature
# Get credentials at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: callback URL override (default: http://localhost:5000/api/auth/google/callback)
# GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ---------------------------------------------------------------------------
# Rate Limiting (optional - tune request quotas)
# ---------------------------------------------------------------------------
# All limits are per IP address over the window duration shown below.
# RATE_LIMIT_API_MAX=1200       # General API: 1200 requests per 15 min
# RATE_LIMIT_AUTH_MAX=40        # Auth endpoints: 40 requests per 15 min
# RATE_LIMIT_MESSAGE_MAX=60     # Messaging: 60 requests per 1 min
# RATE_LIMIT_UPLOAD_MAX=40      # Image uploads: 40 requests per 15 min

# ---------------------------------------------------------------------------
# File Uploads (optional)
# ---------------------------------------------------------------------------
# MAX_UPLOAD_SIZE=2097152       # Max file size in bytes (default: 2 MB = 2*1024*1024)
# MAX_UPLOAD_FILES=8            # Max number of files per upload

# ---------------------------------------------------------------------------
# Image Optimization (optional)
# ---------------------------------------------------------------------------
# IMAGE_FORMAT=jpeg             # Output format: "jpeg" (default) or "webp"
# IMAGE_QUALITY=80              # Compression quality 1-100 (default: 80)
# IMAGE_MAX_WIDTH=1920          # Resize images wider than this (default: 1920px)
# IMAGE_MAX_HEIGHT=1080         # Resize images taller than this (default: 1080px)
# IMAGE_THUMBNAILS=true         # Generate webp thumbnails: "true" (default) or "false"

# ---------------------------------------------------------------------------
# SMTP / Email (optional)
# ---------------------------------------------------------------------------
# Used for welcome emails, password resets, notifications, etc.
# Required for: email notifications feature
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="TechTregu" <noreply@techtregu.com>

# =============================================================================
# Backup (run on your DB host or as a cron job)
# =============================================================================
# mysqldump -u"$MYSQL_USER" -p"$MYSQL_PASSWORD" "$MYSQL_DATABASE" > techtregu-backup-$(date +%F).sql

# =============================================================================
# Production Security Checklist
# =============================================================================
# [ ] JWT_SECRET: 32+ random characters (server refuses to start if < 32)
# [ ] SESSION_SECRET: set a unique value if Google OAuth is enabled
# [ ] CORS_ORIGINS: list only your real front-end origins (comma-separated)
# [ ] NODE_ENV=production
# [ ] Terminate TLS at your reverse proxy (cookies use Secure in production)
# [ ] GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET: for Google OAuth (if needed)
# [ ] SMTP_*: configure if email notifications are required
